# ─── Discogs Conversational Analytics Agent — V1 ───────────────────
# Copy to .env in the repo root and fill in. .env is gitignored.

# Required: OpenAI key for the cheap/strong model tiers.
OPENAI_API_KEY=

# Model tier defaults (override only if you have a reason to).
CHEAP_MODEL=gpt-4o-mini
STRONG_MODEL=gpt-4o

# Where the agent reads the published DuckDB. Inside the container.
ANALYTICS_DUCKDB_PATH=/app/data/published/duckdb/discogs.duckdb

# Postgres connection (compose sets this for the container; keep in sync).
DATABASE_URL=postgresql+psycopg://agent:agent@postgres:5432/agent

# Where chart artifacts land. Bind-mounted from ./artifacts at the host.
ARTIFACTS_DIR=/app/artifacts

# Retry budget across safety + validation paths.
MAX_RETRIES=2

# Hard wall-clock cap for the sandbox subprocess.
SANDBOX_TIMEOUT_SECONDS=30

# Multi-turn carry-over (US4). Bounded by both turns and tokens.
THREAD_CARRYOVER_TURNS=4
THREAD_CARRYOVER_TOKEN_BUDGET=512

# LLM backend selector: "openai" (real) or "stub" (in-process; tests only).
LLM_BACKEND=openai

# Logging.
LOG_LEVEL=INFO

# Admin auth for /runs/{id} debug fields and /threads/{id} admin views.
# Empty disables admin mode entirely (default for safety).
AGENT_ADMIN_TOKEN=
